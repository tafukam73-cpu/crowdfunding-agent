# ===== PostgreSQL =====
POSTGRES_USER=cfagent
POSTGRES_PASSWORD=cfagent_password
POSTGRES_DB=crowdfunding
POSTGRES_PORT=5432

# ===== Backend (FastAPI) =====
# db はコンテナ名（docker-compose のサービス名）を指す
DATABASE_URL=postgresql+psycopg://cfagent:cfagent_password@db:5432/crowdfunding
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000

# ===== Frontend (Next.js) =====
# ブラウザからアクセスする URL（localhost）
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_PORT=3000

# ===== スクレイピング =====
# 取得方法: playwright（Cloudflare対策・既定） / httpx（軽量）
SCRAPE_FETCHER=playwright
# リクエスト間隔（秒）。レート制限への配慮
SCRAPE_RATE_LIMIT_SECONDS=2.0
# 取得タイムアウト（秒）
SCRAPE_TIMEOUT_SECONDS=30.0
# リトライ回数（403/429/5xx/タイムアウト時。UA をローテーションして再試行）
SCRAPE_RETRIES=2

# ===== 日次自動収集スケジューラ =====
# 有効化（false で起動時にスケジューラを開始しない）
SCRAPE_SCHEDULE_ENABLED=true
# 実行スケジュール（cron式）。既定は毎日 03:00
SCRAPE_SCHEDULE_CRON=0 3 * * *
# スケジュールのタイムゾーン
SCRAPE_TIMEZONE=Asia/Tokyo
# 自動収集の 1 サイトあたり取得上限
SCRAPE_DAILY_LIMIT=20

# ===== Web Research 検索プロバイダー =====
# メール/SNS/連絡先の検索精度を上げるための検索 API。
# 切り替え: none（既定。DuckDuckGo HTML にフォールバック） / brave / serpapi /
#           tavily / google_cse / bing / multi
# multi は設定済みのプロバイダーを順に試し、最初に結果が返ったものを使う
# （Brave → Google CSE → SerpAPI → Tavily → Bing → DuckDuckGo）。
# APIキーが無ければ自動的に DuckDuckGo（手動検索クエリ方式）にフォールバックする。
# ※ Brave のキーは ASCII のみ（全角/日本語/引用符の混入で全リクエストが失敗します）。
SEARCH_PROVIDER=none
# Brave Search API（https://api.search.brave.com）
BRAVE_SEARCH_API_KEY=
# SerpAPI（https://serpapi.com）
SERPAPI_API_KEY=
# Tavily Search API（https://tavily.com）
TAVILY_API_KEY=
# Google Custom Search JSON API（key と cx の両方が必要）
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
# Bing Web Search API（Azure）
BING_SEARCH_API_KEY=
# 1 クエリあたり取得する検索結果の上限
SEARCH_MAX_RESULTS=10

# ===== AI Search Agent（反復探索）の上限 =====
SEARCH_AGENT_MAX_STEPS=15
SEARCH_AGENT_MAX_URLS=40
SEARCH_AGENT_MAX_QUERIES=50
SEARCH_AGENT_MAX_PER_DOMAIN=8

# ===== 取得アラート通知（構造変化・成功率低下） =====
# Slack Incoming Webhook URL。設定時のみ Slack 通知（未設定なら何もしない）
SLACK_WEBHOOK_URL=
# 管理画面のベース URL（通知本文のリンク用）。未設定なら FRONTEND_ORIGIN を使う
APP_BASE_URL=http://localhost:3000
# 通知判定に使う直近 run 件数
ALERT_WINDOW=20

# ===== AI 評価 =====
# 未設定ならモック評価器/メール生成器が使われる（画面・DB・API は完全に動作）。
# キーを設定すると Claude 実装に自動で切り替わる。
ANTHROPIC_API_KEY=
# 既定は最も高性能な Opus 4.8。コスト重視なら claude-sonnet-4-6 / claude-haiku-4-5 に変更可
ANTHROPIC_MODEL=claude-opus-4-8

# ===== 営業メール 差出人（署名に使用） =====
SENDER_NAME=Taro Yamada
SENDER_COMPANY=Your Company

# ===== メール下書きプロバイダー（Gmail） =====
# 3つ（CLIENT_ID/SECRET/REFRESH_TOKEN）が揃うと Gmail を使用、未設定なら mock。
# 取得方法: Google Cloud で OAuth クライアント(デスクトップ)を作成し、
#   スコープ https://www.googleapis.com/auth/gmail.compose で一度同意して
#   リフレッシュトークンを取得する。送信はせず「下書き」作成のみ行う。
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# 下書きを作成するユーザー（通常 "me"）と From 表示（省略可）
GMAIL_USER=me
GMAIL_SENDER=
